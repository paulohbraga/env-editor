{
  "name": "env-editor",
  "displayName": ".env Editor",
  "description": "View and edit environment variables on macOS (.bashrc / .zshrc) and Windows (System & User vars)",
  "version": "0.1.0",
  "publisher": "env-editor",
  "repository": {
    "type": "git",
    "url": ""
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["environment", "env", "variables", "bashrc", "zshrc", "windows"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "icon": "resources/icon.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "envEditorContainer",
          "title": ".env Editor",
          "icon": "resources/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "envEditorContainer": [
        {
          "type": "webview",
          "id": "envEditor.sidebar",
          "name": ".env Editor"
        }
      ]
    },
    "commands": [
      {
        "command": "envEditor.open",
        "title": "Env Editor: Open Environment Variables"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "envEditor.open"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0"
  }
}
